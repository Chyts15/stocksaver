generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id               String   @id @default(cuid())
  name             String
  currentStock     Float
  reorderThreshold Float
  avgDailySales    Float?
  unit             String   @default("units")
  category         String?
  supplier         String?
  supplierPhone    String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}